# Optional: logs
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# Docker
**/.dockerignore

# DB dumps
*.sql
*.dump

# Composer artifacts (оставляем composer.lock, но игнорируем phar если появится)
composer.phar

# Local secrets for docker-compose
.env