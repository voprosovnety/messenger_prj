# OS / IDE
.DS_Store
.vscode/
.idea/

# Symfony
/backend/app/var/
/backend/app/vendor/
/backend/app/.env.local
/backend/app/.env.*.local
/backend/app/.env.dev
/backend/app/.env.prod
/backend/app/.env.prod.local

# Logs / cache
*.log

# JWT keys (secret!)
/backend/app/config/jwt/*.pem

# Frontend (Vite/Vue)
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.env
frontend/.env.local
